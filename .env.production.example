APP_NAME=Edusfera
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://edusfera.by

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU
APP_TIMEZONE=Europe/Minsk

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=edusfera
DB_USERNAME=edusfera
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=1440
SESSION_ENCRYPT=true

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="support@edusfera.by"
MAIL_FROM_NAME="${APP_NAME}"

PAYMENT_GATEWAY=
PAYMENT_WEBHOOK_SECRET=
PAYMENT_WEBHOOK_ALLOWED_IPS=
PAYMENT_WEBHOOK_REQUIRE_SIGNATURE=true
PAYMENT_WEBHOOK_REQUIRE_IP_ALLOWLIST=true

SITE_ADMIN_SYNC_ENABLED=false
SITE_ADMIN_NAME="Технический администратор"
SITE_ADMIN_EMAIL=
SITE_ADMIN_PASSWORD=

PAYMENTS_LOG_PATH=
PAYMENTS_LOG_LEVEL=info

VITE_APP_NAME="${APP_NAME}"
